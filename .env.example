# North Dent - environment variables (public, exposed to client because PUBLIC_ prefix)
# Copy to .env and fill with real IDs. All tracking is consent-gated.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token (meta tag method).
# Alternatively verify via DNS TXT record or HTML file upload.
PUBLIC_GOOGLE_SITE_VERIFICATION=

# Meta (Facebook) Pixel ID
PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID
PUBLIC_TIKTOK_PIXEL_ID=
