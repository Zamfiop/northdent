---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import WhatsAppButton from "@/components/WhatsAppButton.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import CtaSection from "@/components/CtaSection.astro";
import { getRelatedServices, type Service } from "@/data/services";
import { faqSchema } from "@/lib/schema";
import type { BreadcrumbEntry } from "@/lib/schema";

interface Props {
  service: Service;
}
const { service } = Astro.props;

const path = `/servicii/${service.slug}/`;
const related = getRelatedServices(service);

const breadcrumbs: BreadcrumbEntry[] = [
  { name: "Acasă", path: "/" },
  { name: "Servicii", path: "/servicii/" },
  { name: service.name, path },
];

// FAQ schema DOAR pentru întrebările vizibile pe pagină.
const jsonLd = service.faqs.length > 0 ? faqSchema(service.faqs) : undefined;

const sections: { heading: string; items: string[] }[] = [
  { heading: "Când este recomandat", items: service.whenRecommended },
  { heading: "Cum decurge", items: service.howItWorks },
  { heading: "La ce să te aștepți", items: service.whatToExpect },
];
---

<BaseLayout
  title={service.title}
  description={service.description}
  path={path}
  jsonLd={jsonLd}
>
  <section class="bg-gradient-to-b from-primary-50/60 to-white">
    <Container class="py-10 sm:py-14">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="mt-5 text-3xl font-extrabold leading-tight text-ink sm:text-4xl">
        {service.h1}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-soft">
        {service.intro}
      </p>
      {/* CTA WhatsApp sus */}
      <div class="mt-6">
        <WhatsAppButton size="lg" message={`Bună ziua! Aș dori o programare pentru ${service.name}.`} />
      </div>
    </Container>
  </section>

  <Container class="py-12">
    <div class="grid gap-10 lg:grid-cols-3">
      <div class="space-y-10 lg:col-span-2">
        {
          service.body.length > 0 && (
            <section class="space-y-4 text-base leading-relaxed text-ink-soft">
              {service.body.map((paragraph) => (
                <p>{paragraph}</p>
              ))}
            </section>
          )
        }
        {
          sections.map((section) => (
            <section>
              <h2 class="text-xl font-bold text-ink">{section.heading}</h2>
              <ul class="mt-4 space-y-3">
                {section.items.map((item) => (
                  <li class="flex items-start gap-3 text-ink-soft">
                    <svg class="mt-1 h-5 w-5 shrink-0 text-primary-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
                    </svg>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }

        {/* Slot pentru conținut suplimentar specific paginii (TODO: text final) */}
        <slot />

        {
          service.faqs.length > 0 && (
            <section>
              <h2 class="text-xl font-bold text-ink">Întrebări frecvente</h2>
              <div class="mt-4">
                <FaqAccordion faqs={service.faqs} />
              </div>
            </section>
          )
        }
      </div>

      <aside class="space-y-6 lg:col-span-1">
        <div class="rounded-2xl border border-secondary-100 bg-surface-muted p-6">
          <h2 class="text-base font-bold text-ink">Programează-te rapid</h2>
          <p class="mt-2 text-sm text-ink-soft">
            Scrie-ne pe WhatsApp și îți propunem un interval potrivit.
          </p>
          <div class="mt-4">
            <WhatsAppButton fullWidth message={`Bună ziua! Aș dori o programare pentru ${service.name}.`} />
          </div>
        </div>

        {
          related.length > 0 && (
            <nav class="rounded-2xl border border-secondary-100 p-6" aria-label="Servicii conexe">
              <h2 class="text-base font-bold text-ink">Servicii conexe</h2>
              <ul class="mt-3 space-y-2 text-sm">
                {related.map((r) => (
                  <li>
                    <a href={`/servicii/${r.slug}/`} class="text-primary-700 hover:text-primary-800">
                      {r.name}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )
        }
      </aside>
    </div>
  </Container>

  <CtaSection message={`Bună ziua! Aș dori o programare pentru ${service.name}.`} />
</BaseLayout>
