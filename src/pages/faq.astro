---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import FaqAccordion from "@/components/FaqAccordion.astro";
import CtaSection from "@/components/CtaSection.astro";
import { generalFaqCategories, generalFaqs } from "@/data/faqs";
import { site } from "@/data/site";
import { faqSchema } from "@/lib/schema";
import type { BreadcrumbEntry } from "@/lib/schema";

const breadcrumbs: BreadcrumbEntry[] = [
  { name: "Acasă", path: "/" },
  { name: "Întrebări frecvente", path: "/faq/" },
];
// FAQ schema DOAR pentru întrebările vizibile pe pagină.
---

<BaseLayout
  title="Întrebări frecvente stomatologie | North Dent Râmnicu Vâlcea"
  description="Răspunsuri detaliate despre programări, consultații, tratamente dentare, copii, pacienți anxioși, durere și costuri la cabinetul stomatologic North Dent din Zona Nord, Râmnicu Vâlcea."
  path="/faq/"
  jsonLd={faqSchema(generalFaqs)}
>
  <section class="bg-gradient-to-b from-primary-50/60 to-white">
    <Container class="py-10 sm:py-14">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="mt-5 text-3xl font-extrabold text-ink sm:text-4xl">
        Întrebări frecvente despre stomatologie
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-soft">
        Răspunsuri la întrebările pe care le primim cel mai des la
        <strong class="font-semibold text-ink">North Dent</strong>, cabinet
        stomatologic din {site.address.areaLabel}. Găsești informații despre
        programări pe WhatsApp, consultații, igienizare, tratamente dentare,
        stomatologie pentru copii și situații de urgență. Dacă nu găsești ce
        cauți, scrie-ne la {site.phoneDisplay}.
      </p>
      <nav
        class="mt-8 rounded-2xl border border-secondary-100 bg-white p-5"
        aria-label="Categorii întrebări frecvente"
      >
        <p class="text-sm font-semibold text-secondary-800">Navigare rapidă</p>
        <ul class="mt-3 flex flex-wrap gap-2">
          {
            generalFaqCategories.map((cat) => (
              <li>
                <a
                  href={`#${cat.id}`}
                  class="inline-block rounded-full bg-primary-50 px-3 py-1.5 text-sm font-medium text-primary-700 transition-colors hover:bg-primary-100"
                >
                  {cat.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </Container>
  </section>

  <section class="py-12">
    <Container class="space-y-14">
      {
        generalFaqCategories.map((category) => (
          <article id={category.id} class="scroll-mt-24">
            <h2 class="text-2xl font-bold text-ink">{category.title}</h2>
            {category.description && (
              <p class="mt-2 text-base leading-relaxed text-ink-soft">
                {category.description}
              </p>
            )}
            <div class="mt-6">
              <FaqAccordion faqs={category.faqs} />
            </div>
          </article>
        ))
      }
    </Container>
  </section>

  <CtaSection />
</BaseLayout>
