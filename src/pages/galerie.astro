---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/Container.astro";
import Breadcrumbs from "@/components/Breadcrumbs.astro";
import CtaSection from "@/components/CtaSection.astro";
import { site } from "@/data/site";
import { galleryImages } from "@/data/gallery";
import type { BreadcrumbEntry } from "@/lib/schema";

const breadcrumbs: BreadcrumbEntry[] = [
  { name: "Acasă", path: "/" },
  { name: "Galerie", path: "/galerie/" },
];
---

<BaseLayout
  title="Galerie foto cabinet North Dent | Râmnicu Vâlcea"
  description="Galerie foto North Dent — cabinet stomatologic din Zona Nord, Râmnicu Vâlcea. Imagini din spațiul de tratament, echipament și echipa medicală."
  path="/galerie/"
>
  <section class="bg-gradient-to-b from-primary-50/60 to-white">
    <Container class="py-10 sm:py-14">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="mt-5 text-3xl font-extrabold text-ink sm:text-4xl">
        Galerie foto
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-soft">
        Imagini din cabinetul North Dent din {site.address.areaLabel} — spații de
        tratament, echipament și echipa care te întâmpină la fiecare vizită.
      </p>
    </Container>
  </section>

  <section class="py-12">
    <Container>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          galleryImages.map((item) => (
            <figure class="overflow-hidden rounded-2xl border border-secondary-100 bg-white shadow-sm">
              <img
                src={item.src}
                alt={item.alt}
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
                class="aspect-[4/3] w-full object-cover"
              />
              <figcaption class="p-3 text-sm text-ink-soft">{item.alt}</figcaption>
            </figure>
          ))
        }
      </div>
    </Container>
  </section>

  <CtaSection />
</BaseLayout>
