---
// Consent Mode v2 — trebuie în <head>, înainte de orice script Google.
// Fără asta, GA4 poate încărca gtag.js dar nu trimite hit-uri (collect) în EEA.
---
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("consent", "default", {
    analytics_storage: "denied",
    ad_storage: "denied",
    ad_user_data: "denied",
    ad_personalization: "denied",
    wait_for_update: 500,
  });
</script>
