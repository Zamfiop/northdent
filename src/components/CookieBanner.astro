---
// Cookie banner GDPR custom, în română.
// Blochează GA / Meta Pixel / TikTok Pixel până la consimțământ.
---

<div
  id="cookie-banner"
  hidden
  role="dialog"
  aria-modal="false"
  aria-label="Preferințe cookies"
  aria-live="polite"
  class="fixed inset-x-0 bottom-0 z-50 p-3 sm:p-4"
>
  <div class="mx-auto max-w-3xl rounded-2xl border border-secondary-100 bg-white p-5 shadow-2xl shadow-secondary-900/10">
    <h2 class="text-base font-bold text-ink">Respectăm confidențialitatea ta</h2>
    <p class="mt-2 text-sm leading-relaxed text-ink-soft">
      Folosim cookie-uri necesare pentru funcționarea site-ului și, doar cu
      acordul tău, cookie-uri de analiză și marketing. Poți accepta, respinge
      sau personaliza preferințele. Detalii în
      <a href="/politica-cookies/" class="text-primary-700 underline">Politica cookies</a>
      și
      <a href="/politica-de-confidentialitate/" class="text-primary-700 underline">Politica de confidențialitate</a>.
    </p>
    <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
      <button type="button" data-consent-action="accept-all" class="rounded-full bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-700">
        Accept toate
      </button>
      <button type="button" data-consent-action="reject-optional" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-secondary-800 ring-1 ring-inset ring-secondary-200 hover:bg-secondary-50">
        Respinge opționale
      </button>
      <button type="button" data-consent-action="customize" class="rounded-full px-5 py-2.5 text-sm font-semibold text-primary-700 underline underline-offset-4 hover:text-primary-800">
        Personalizează
      </button>
    </div>
  </div>
</div>

<div
  id="cookie-preferences"
  hidden
  role="dialog"
  aria-modal="true"
  aria-labelledby="cookie-preferences-title"
  class="fixed inset-0 z-50"
>
  <div id="cookie-preferences-overlay" class="absolute inset-0 bg-secondary-900/50"></div>
  <div class="absolute inset-x-0 bottom-0 mx-auto max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-t-3xl bg-white p-6 shadow-2xl sm:inset-0 sm:m-auto sm:h-fit sm:rounded-3xl">
    <div class="flex items-start justify-between">
      <h2 id="cookie-preferences-title" class="text-lg font-bold text-ink">
        Setări cookies
      </h2>
      <button type="button" id="cookie-preferences-close" aria-label="Închide" class="rounded-md p-1 text-secondary-700 hover:bg-secondary-50">
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="mt-4 space-y-4">
      <div class="rounded-xl border border-secondary-100 p-4">
        <div class="flex items-center justify-between">
          <h3 class="font-semibold text-ink">Necesare</h3>
          <span class="rounded-full bg-secondary-100 px-3 py-1 text-xs font-medium text-secondary-700">Mereu active</span>
        </div>
        <p class="mt-2 text-sm text-ink-soft">
          Esențiale pentru funcționarea site-ului și pentru salvarea preferințelor
          tale de consimțământ. Nu pot fi dezactivate.
        </p>
      </div>

      <label class="flex cursor-pointer items-start justify-between gap-4 rounded-xl border border-secondary-100 p-4">
        <span>
          <span class="block font-semibold text-ink">Analiză</span>
          <span class="mt-1 block text-sm text-ink-soft">
            Google Analytics, pentru a înțelege cum este folosit site-ul. Se
            activează doar cu acordul tău.
          </span>
        </span>
        <input type="checkbox" id="consent-analytics" class="mt-1 h-5 w-5 shrink-0 rounded border-secondary-300 text-primary-600 focus:ring-primary-500" />
      </label>

      <label class="flex cursor-pointer items-start justify-between gap-4 rounded-xl border border-secondary-100 p-4">
        <span>
          <span class="block font-semibold text-ink">Marketing</span>
          <span class="mt-1 block text-sm text-ink-soft">
            Meta Pixel și TikTok Pixel, pentru măsurarea campaniilor. Se
            activează doar cu acordul tău.
          </span>
        </span>
        <input type="checkbox" id="consent-marketing" class="mt-1 h-5 w-5 shrink-0 rounded border-secondary-300 text-primary-600 focus:ring-primary-500" />
      </label>
    </div>

    <div class="mt-6 flex flex-col gap-2 sm:flex-row">
      <button type="button" data-consent-action="save" class="rounded-full bg-primary-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary-700">
        Salvează preferințele
      </button>
      <button type="button" data-consent-action="accept-all" class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-secondary-800 ring-1 ring-inset ring-secondary-200 hover:bg-secondary-50">
        Accept toate
      </button>
    </div>
    <p class="mt-4 text-xs text-ink-soft">
      Detalii: <a href="/politica-cookies/" class="text-primary-700 underline">Politica cookies</a>.
    </p>
  </div>
</div>

<script>
  import {
    getConsent,
    saveConsent,
    acceptAll,
    rejectOptional,
  } from "@/lib/consent";

  const banner = document.getElementById("cookie-banner");
  const prefs = document.getElementById("cookie-preferences");
  const overlay = document.getElementById("cookie-preferences-overlay");
  const closeBtn = document.getElementById("cookie-preferences-close");
  const analyticsInput = document.getElementById(
    "consent-analytics",
  ) as HTMLInputElement | null;
  const marketingInput = document.getElementById(
    "consent-marketing",
  ) as HTMLInputElement | null;

  function showBanner() {
    banner?.removeAttribute("hidden");
  }
  function hideBanner() {
    banner?.setAttribute("hidden", "");
  }
  function openPrefs() {
    const current = getConsent();
    if (analyticsInput) analyticsInput.checked = current?.analytics ?? false;
    if (marketingInput) marketingInput.checked = current?.marketing ?? false;
    prefs?.removeAttribute("hidden");
    document.body.style.overflow = "hidden";
  }
  function closePrefs() {
    prefs?.setAttribute("hidden", "");
    document.body.style.overflow = "";
  }

  // Afișează bannerul doar dacă nu există o decizie salvată.
  if (!getConsent()) showBanner();

  document.querySelectorAll("[data-consent-action]").forEach((el) => {
    el.addEventListener("click", () => {
      const action = (el as HTMLElement).dataset.consentAction;
      switch (action) {
        case "accept-all":
          acceptAll();
          hideBanner();
          closePrefs();
          break;
        case "reject-optional":
          rejectOptional();
          hideBanner();
          break;
        case "customize":
          openPrefs();
          break;
        case "save":
          saveConsent({
            analytics: analyticsInput?.checked ?? false,
            marketing: marketingInput?.checked ?? false,
          });
          hideBanner();
          closePrefs();
          break;
      }
    });
  });

  closeBtn?.addEventListener("click", closePrefs);
  overlay?.addEventListener("click", closePrefs);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !prefs?.hasAttribute("hidden")) closePrefs();
  });

  // Link din footer "Setări cookies" redeschide panoul.
  document
    .getElementById("open-cookie-settings")
    ?.addEventListener("click", openPrefs);
</script>
