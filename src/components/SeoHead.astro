---
import { resolveSeo, type SeoInput } from "@/lib/seo";
import { site } from "@/data/site";

interface Props extends SeoInput {}

const seo = resolveSeo(Astro.props);
const gsv = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION as string | undefined;
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
<meta name="robots" content={seo.robots} />

{/* Google Search Console: metoda meta tag.
    Alternativ, se poate verifica prin DNS TXT sau upload fișier HTML. */}
{gsv && <meta name="google-site-verification" content={gsv} />}

{/* Open Graph */}
<meta property="og:type" content={seo.ogType} />
<meta property="og:site_name" content={seo.siteName} />
<meta property="og:locale" content={seo.locale} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.image} />

{/* Twitter / X card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
<meta name="twitter:image" content={seo.image} />

<meta name="author" content={site.brand} />
<meta name="geo.region" content="RO-VL" />
<meta name="geo.placename" content="Râmnicu Vâlcea" />
