---
import { site, formatOpeningHours } from "@/data/site";

interface Props {
  /** Afișează programul */
  showHours?: boolean;
  /** Link către Google Maps sub adresă */
  showMapsLink?: boolean;
  class?: string;
}
const { showHours = true, showMapsLink = true, class: className = "" } = Astro.props;
const hours = formatOpeningHours();
---

<div class={`space-y-6 ${className}`}>
  <ul class="space-y-4">
    <li class="flex items-start gap-3">
      <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-700" aria-hidden="true">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/></svg>
      </span>
      <span>
        <span class="block text-sm font-semibold text-ink">Adresă</span>
        <span class="text-sm text-ink-soft">{site.address.streetAddress}, {site.address.addressLocality}</span>
        {
          showMapsLink && (
            <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer" data-track="maps_click" class="mt-1 block text-sm font-medium text-primary-700 hover:text-primary-800">
              Vezi locația pe hartă
            </a>
          )
        }
      </span>
    </li>

    <li class="flex items-start gap-3">
      <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-700" aria-hidden="true">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/></svg>
      </span>
      <span>
        <span class="block text-sm font-semibold text-ink">Telefon / WhatsApp</span>
        <a href={`tel:${site.phoneHref}`} data-track="phone_click" class="text-sm text-ink-soft hover:text-primary-700">{site.phoneDisplay}</a>
      </span>
    </li>

    <li class="flex items-start gap-3">
      <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary-50 text-primary-700" aria-hidden="true">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25H4.5a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5H4.5a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/></svg>
      </span>
      <span>
        <span class="block text-sm font-semibold text-ink">Email</span>
        <a href={site.emailHref} data-track="contact_email_click" class="text-sm text-ink-soft hover:text-primary-700">{site.email}</a>
      </span>
    </li>
  </ul>

  {
    showHours && (
      <div class="rounded-2xl border border-secondary-100 bg-surface-muted p-4 sm:p-5">
        {/* TODO: programul este temporar și se va schimba curând */}
        <h3 class="text-sm font-semibold text-ink">Program (temporar)</h3>
        <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-1 text-sm text-ink-soft sm:grid-cols-1">
          {hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.label}</span>
              <span class="tabular-nums">{h.value}</span>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</div>
