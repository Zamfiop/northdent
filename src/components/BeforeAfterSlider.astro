---
// Slider draggable de comparație „înainte / după".
// Ambele imagini sunt afișate la lățime completă; imaginea „înainte" este
// decupată cu clip-path în funcție de poziția slider-ului (fără squash).
interface Props {
  before: string;
  beforeAlt: string;
  after: string;
  afterAlt: string;
  /** Mențiune discretă sub imagine (ex. „Caz real. Rezultatele diferă.") */
  note?: string;
  class?: string;
}
const {
  before,
  beforeAlt,
  after,
  afterAlt,
  note,
  class: className = "",
} = Astro.props;
---

<figure class={`mx-auto w-full max-w-md ${className}`}>
  <div
    class="ba relative aspect-[4/5] w-full select-none overflow-hidden rounded-3xl shadow-xl ring-1 ring-secondary-100"
    data-ba
  >
    {/* După (bază) */}
    <img
      src={after}
      alt={afterAlt}
      width="640"
      height="800"
      decoding="async"
      draggable="false"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <span class="pointer-events-none absolute right-3 top-3 z-10 rounded-full bg-secondary-900/70 px-2.5 py-1 text-xs font-semibold text-white">
      După
    </span>

    {/* Înainte (decupat) */}
    <div class="ba-before absolute inset-0">
      <img
        src={before}
        alt={beforeAlt}
        width="640"
        height="800"
        decoding="async"
        draggable="false"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <span class="pointer-events-none absolute left-3 top-3 rounded-full bg-white/85 px-2.5 py-1 text-xs font-semibold text-ink">
        Înainte
      </span>
    </div>

    {/* Mâner */}
    <div class="ba-handle pointer-events-none absolute inset-y-0 z-10 w-0.5 -translate-x-1/2 bg-white/90">
      <span class="absolute top-1/2 left-1/2 flex h-10 w-10 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white shadow-lg ring-1 ring-secondary-200">
        <svg class="h-5 w-5 text-secondary-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m9 7-5 5 5 5" />
          <path d="m15 7 5 5-5 5" />
        </svg>
      </span>
    </div>

    {/* Control accesibil (tastatură + drag) */}
    <input
      type="range"
      min="0"
      max="100"
      value="50"
      step="1"
      class="ba-range absolute inset-0 z-20 h-full w-full cursor-ew-resize appearance-none bg-transparent opacity-0"
      aria-label="Compară imaginile: înainte și după albire"
    />
  </div>
  {note && <figcaption class="mt-2 text-center text-xs text-ink-soft">{note}</figcaption>}
</figure>

<style>
  .ba {
    --pos: 50%;
  }
  .ba-before {
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }
  .ba-handle {
    left: var(--pos);
  }
</style>

<script>
  function initBeforeAfter(root: HTMLElement): void {
    const range = root.querySelector<HTMLInputElement>(".ba-range");
    if (!range) return;
    const update = () => root.style.setProperty("--pos", range.value + "%");
    range.addEventListener("input", update);
    update();
  }

  document.querySelectorAll<HTMLElement>("[data-ba]").forEach(initBeforeAfter);
</script>
