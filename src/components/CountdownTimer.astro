---
// Countdown către un deadline REAL de campanie (dată din src/data/offers.ts).
// După expirare, ascunde timer-ul și afișează un mesaj neutru; CTA rămâne activ.
interface Props {
  /** Deadline ISO cu fus orar, ex. "2026-07-10T23:59:00+03:00" */
  deadline: string;
  variant?: "bar" | "block";
  expiredText?: string;
  class?: string;
}
const {
  deadline,
  variant = "block",
  expiredText = "Oferta s-a încheiat",
  class: className = "",
} = Astro.props;

const units = [
  { key: "days", label: "zile" },
  { key: "hours", label: "ore" },
  { key: "minutes", label: "min" },
  { key: "seconds", label: "sec" },
];

const isBar = variant === "bar";
---

<div
  class:list={[
    "countdown",
    isBar ? "inline-block" : "mx-auto w-full max-w-lg",
    className,
  ]}
  data-countdown
  data-deadline={deadline}
  role="timer"
  aria-label="Timp rămas din ofertă"
>
  <div
    class:list={[
      "countdown-live",
      isBar
        ? "inline-flex items-center gap-1.5 sm:gap-2"
        : "flex w-full items-center justify-center gap-1 sm:gap-2 md:gap-3",
    ]}
  >
    {
      units.map((u, i) => (
        <>
          <div
            class:list={[
              isBar
                ? "flex min-w-[2.25rem] flex-col items-center leading-none sm:min-w-[2.75rem]"
                : "flex min-w-0 flex-[1_1_0] max-w-[4.75rem] flex-col items-center justify-center rounded-xl bg-white/95 px-2 py-2.5 shadow-sm ring-1 ring-inset ring-primary-100 sm:max-w-none sm:flex-none sm:min-w-[4.5rem] sm:px-4 sm:py-3",
            ]}
          >
            <span
              class:list={[
                "font-extrabold tabular-nums",
                isBar
                  ? "text-sm text-white sm:text-base"
                  : "text-xl text-primary-700 sm:text-2xl md:text-3xl",
              ]}
              data-unit={u.key}
            >
              --
            </span>
            <span
              class:list={[
                "font-medium uppercase tracking-wide",
                isBar
                  ? "text-[9px] text-white/80 sm:text-[10px]"
                  : "mt-1 text-[10px] text-ink-soft sm:text-[11px]",
              ]}
            >
              {u.label}
            </span>
          </div>
          {i < units.length - 1 && (
            <span
              class:list={[
                "shrink-0 font-bold",
                isBar
                  ? "pb-3 text-sm text-white/60 sm:pb-3.5 sm:text-base"
                  : "pb-4 text-lg text-primary-300 sm:pb-5 sm:text-2xl md:text-3xl",
              ]}
              aria-hidden="true"
            >
              :
            </span>
          )}
        </>
      ))
    }
  </div>
  <p
    class:list={[
      "countdown-expired hidden",
      isBar ? "text-sm font-semibold text-white" : "text-base font-semibold text-white",
    ]}
  >
    {expiredText}
  </p>
</div>

<script>
  function pad(value: number): string {
    return value < 10 ? "0" + value : String(value);
  }

  function initCountdown(root: HTMLElement): void {
    const raw = root.dataset.deadline;
    if (!raw) return;
    const deadline = new Date(raw).getTime();
    if (Number.isNaN(deadline)) return;

    const live = root.querySelector<HTMLElement>(".countdown-live");
    const expired = root.querySelector<HTMLElement>(".countdown-expired");
    const cells = root.querySelectorAll<HTMLElement>("[data-unit]");

    let timerId = 0;

    function tick(): void {
      const diff = deadline - Date.now();
      if (diff <= 0) {
        live?.classList.add("hidden");
        expired?.classList.remove("hidden");
        root.dataset.state = "expired";
        if (timerId) window.clearInterval(timerId);
        return;
      }
      const values: Record<string, string> = {
        days: pad(Math.floor(diff / 86400000)),
        hours: pad(Math.floor((diff % 86400000) / 3600000)),
        minutes: pad(Math.floor((diff % 3600000) / 60000)),
        seconds: pad(Math.floor((diff % 60000) / 1000)),
      };
      cells.forEach((cell) => {
        const unit = cell.dataset.unit;
        if (unit && values[unit] !== undefined) cell.textContent = values[unit];
      });
    }

    tick();
    timerId = window.setInterval(tick, 1000);
  }

  document
    .querySelectorAll<HTMLElement>("[data-countdown]")
    .forEach(initCountdown);
</script>
