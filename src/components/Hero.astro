---
import Container from "@/components/Container.astro";
import WhatsAppButton from "@/components/WhatsAppButton.astro";
import { site } from "@/data/site";

interface Props {
  title: string;
  subtitle?: string;
  trustIndicators?: string[];
}
const { title, subtitle, trustIndicators = [] } = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-b from-primary-50 via-white to-white">
  <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-primary-100/60 blur-3xl" aria-hidden="true"></div>
  <Container class="relative grid items-center gap-10 py-14 sm:py-20 lg:grid-cols-2">
    <div>
      <p class="inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-sm font-medium text-primary-700 ring-1 ring-inset ring-primary-100">
        <span class="h-2 w-2 rounded-full bg-primary-500"></span>
        {site.address.areaLabel}
      </p>
      <h1 class="mt-4 text-3xl font-extrabold leading-tight text-ink sm:text-4xl lg:text-5xl">
        {title}
      </h1>
      {subtitle && <p class="mt-4 max-w-xl text-lg leading-relaxed text-ink-soft">{subtitle}</p>}

      <div class="mt-7 flex w-full max-w-md flex-col gap-3">
        <WhatsAppButton size="lg" fullWidth />
        <a
          href={site.mapsUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-track="maps_click"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-white px-7 py-3.5 text-center text-base font-semibold leading-snug text-secondary-800 ring-1 ring-inset ring-secondary-200 hover:bg-secondary-50"
        >
          Vezi locația pe hartă
        </a>
      </div>

      {
        trustIndicators.length > 0 && (
          <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-ink-soft">
            {trustIndicators.map((t) => (
              <li class="flex items-center gap-2">
                <svg class="h-5 w-5 text-primary-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
                </svg>
                {t}
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div class="relative">
      <div class="aspect-[4/3] w-full overflow-hidden rounded-3xl shadow-xl ring-1 ring-secondary-100">
        <img
          src={site.cabinet.photo}
          alt={site.cabinet.photoAlt}
          width="800"
          height="600"
          fetchpriority="high"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
  </Container>
</section>
