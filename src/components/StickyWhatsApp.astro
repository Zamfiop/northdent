---
import { whatsappLink } from "@/data/site";
// Buton sticky WhatsApp, discret, pe mobil și desktop.
const href = whatsappLink();
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  data-track="whatsapp_click"
  data-track-category="sticky"
  aria-label="Programează-te pe WhatsApp"
  class="group fixed bottom-4 right-4 z-30 flex items-center gap-2 rounded-full bg-primary-600 py-3 pl-3 pr-4 text-white shadow-lg shadow-primary-900/25 transition-transform duration-200 hover:bg-primary-700 hover:scale-105 sm:bottom-6 sm:right-6"
>
  <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
    <path d="M12.04 2c-5.46 0-9.91 4.45-9.91 9.91 0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91S17.5 2 12.04 2Zm5.8 14.02c-.24.68-1.42 1.32-1.95 1.36-.5.05-.97.24-3.27-.68-2.75-1.08-4.5-3.9-4.64-4.08-.14-.19-1.11-1.48-1.11-2.82 0-1.34.7-2 .95-2.27.24-.27.53-.34.71-.34.18 0 .35 0 .5.01.16.01.38-.06.6.46.24.56.8 1.94.87 2.08.07.14.12.31.02.5-.09.19-.14.31-.28.48-.14.16-.29.36-.42.48-.14.14-.28.29-.12.57.16.27.71 1.17 1.53 1.9 1.05.94 1.94 1.23 2.22 1.37.28.14.44.12.6-.07.16-.19.69-.8.87-1.08.18-.27.36-.22.6-.13.24.09 1.55.73 1.81.86.27.14.45.2.51.31.07.11.07.63-.17 1.31Z"></path>
  </svg>
  <span class="text-sm font-semibold">Scrie-ne</span>
</a>
