---
import { site, formatOpeningHours } from "@/data/site";
import { mainNav, legalNav, secondaryNav } from "@/data/navigation";
import { getFeaturedServices } from "@/data/services";
import Logo from "@/components/Logo.astro";

const hours = formatOpeningHours();
const featured = getFeaturedServices().slice(0, 6);
const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-secondary-100 bg-surface-muted">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-4 lg:px-8">
    <div>
      <Logo />
      <p class="mt-3 text-sm leading-relaxed text-ink-soft">
        Cabinet stomatologic modern în Zona Nord din Râmnicu Vâlcea. Abordare
        calmă, empatică și profesionistă.
      </p>
      <address class="mt-4 not-italic text-sm text-ink-soft">
        {site.address.streetAddress}<br />
        {site.address.addressLocality}
      </address>
      <div class="mt-4 space-y-1 text-sm">
        <a href={`tel:${site.phoneHref}`} data-track="phone_click" class="block font-medium text-secondary-800 hover:text-primary-700">
          {site.phoneDisplay}
        </a>
        <a href={site.emailHref} data-track="contact_email_click" class="block text-ink-soft hover:text-primary-700">
          {site.email}
        </a>
        <a href={site.mapsUrl} target="_blank" rel="noopener noreferrer" data-track="maps_click" class="block text-ink-soft hover:text-primary-700">
          Vezi locația pe hartă
        </a>
      </div>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-secondary-800">Navigare</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          [...mainNav, ...secondaryNav].map((item) => (
            <li>
              <a href={item.href} class="text-ink-soft hover:text-primary-700">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-secondary-800">Servicii</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {
          featured.map((s) => (
            <li>
              <a href={`/servicii/${s.slug}/`} class="text-ink-soft hover:text-primary-700">
                {s.name}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/servicii/" class="font-medium text-primary-700 hover:text-primary-800">
            Toate serviciile
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h2 class="text-sm font-semibold uppercase tracking-wide text-secondary-800">Program</h2>
      {/* TODO: programul este temporar și se va schimba curând */}
      <ul class="mt-4 space-y-1 text-sm text-ink-soft">
        {
          hours.map((h) => (
            <li class="flex justify-between gap-4">
              <span>{h.label}</span>
              <span class="tabular-nums">{h.value}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-secondary-100">
    <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-6 text-sm text-ink-soft sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        {
          legalNav.map((item) => (
            <a href={item.href} class="hover:text-primary-700">
              {item.label}
            </a>
          ))
        }
        <button
          type="button"
          id="open-cookie-settings"
          class="text-left hover:text-primary-700"
        >
          Setări cookies
        </button>
      </div>
      <p>
        © {year} {site.brand} — {site.legalName}. Toate drepturile rezervate.
      </p>
    </div>
  </div>
</footer>
