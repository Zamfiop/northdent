---
import type { Review } from "@/data/reviews";

interface Props {
  review: Review;
}
const { review } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < review.rating);
---

<figure class="flex h-full flex-col rounded-2xl border border-secondary-100 bg-white p-5 shadow-sm">
  <div class="flex items-center gap-1" aria-label={`Rating ${review.rating} din 5`}>
    {
      stars.map((filled) => (
        <svg class={filled ? "h-5 w-5 text-amber-400" : "h-5 w-5 text-secondary-200"} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 15l-5.3 2.6 1-5.8L1.5 7.7l5.9-.9L10 1.5Z" />
        </svg>
      ))
    }
  </div>
  <blockquote class="mt-3 flex-1 text-sm leading-relaxed text-ink-soft">
    „{review.text}"
  </blockquote>
  <figcaption class="mt-4 flex items-center gap-3">
    <span class="flex h-9 w-9 items-center justify-center rounded-full bg-primary-50 text-sm font-semibold text-primary-700" aria-hidden="true">
      {review.initials ?? review.authorName.slice(0, 2)}
    </span>
    <span class="text-sm">
      <span class="block font-semibold text-ink">{review.authorName}</span>
      <span class="text-ink-soft">
        {review.source}{review.date ? ` · ${review.date}` : ""}
      </span>
    </span>
  </figcaption>
</figure>
